{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed:roles": "ts-node-dev --transpile-only src/scripts/seedRoles.ts",
    "db:seed:news-categories": "ts-node-dev --transpile-only src/scripts/seedNewsCategories.ts",
    "db:seed:document-categories": "ts-node-dev --transpile-only src/scripts/seedDocumentCategories.ts",
    "db:seed:shop-categories": "ts-node-dev --transpile-only src/scripts/seedShopCategories.ts",
    "db:seed:board-roles": "ts-node-dev --transpile-only src/scripts/seedBoardRoles.ts",
    "db:seed:all": "npm run db:seed:roles && npm run db:seed:news-categories && npm run db:seed:document-categories && npm run db:seed:shop-categories && npm run db:seed:board-roles"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.12",
    "pg": "^8.17.1",
    "sharp": "^0.34.5",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.9",
    "@types/nodemailer": "^7.0.5",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "prisma": "^7.2.0",
    "supertest": "^7.1.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
