generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =========================================================
// 1. ENUMS (Status e Tipos)
// =========================================================

enum UserStatus {
  ACTIVE
  DISABLED
  PENDING
}

enum PostStatus {
  DRAFT
  PUBLISHED
  HIDDEN
}

enum DocumentStatus {
  PUBLISHED
  HIDDEN
  ARCHIVED
}

enum AssetType {
  IMAGE
  FILE
  LINK
}

enum NewsAssetRole {
  COVER
  GALLERY
  ATTACHMENT
}

// ✅ TMP uploads (para commit atômico)
enum TempAssetKind {
  NEWS_COVER
  NEWS_GALLERY
  SHOP_COVER
  SHOP_GALLERY
}

// --- Lojinha (marketplace) ---
enum ShopProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ShopOrderStatus {
  AWAITING_PAYMENT
  PAYMENT_RECEIVED
  CONFIRMED
  PROCESSING
  READY_FOR_PICKUP
  SHIPPED
  DELIVERED
  CANCELLED
}

enum ShopPaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  FAILED
}

enum ShopPaymentMethod {
  UNKNOWN
  PIX
  CREDIT_CARD
  DEBIT_CARD
  BOLETO
  CASH_ON_DELIVERY
  MANUAL
  OTHER
}

// =========================================================
// 2. AUTH & SEGURANÇA (RBAC)
// =========================================================

model Role {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  color    String  @default("#000000")
  isSystem Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  permissions Permission[]
  invites     Invite[]
}

model Permission {
  id          String @id @default(cuid())
  slug        String @unique
  description String
  module      String

  roles Role[]

  @@map("permissions")
}

model Invite {
  id    String @id @default(cuid())
  email String
  token String @unique

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  expiresAt DateTime
  used      Boolean  @default(false)
  createdBy String

  createdAt DateTime @default(now())

  @@map("invites")
}

model User {
  id                String  @id @default(cuid())
  name              String
  email             String  @unique
  passwordHash      String?
  mustResetPassword Boolean @default(false)
  avatarUrl         String?

  status UserStatus @default(ACTIVE)

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  uploadedDocuments Document[] @relation("DocumentUploader")
  posts             NewsPost[] @relation("PostAuthor")
  edits             NewsPost[] @relation("PostEditor")

  // ✅ TMP uploads (fase A do fluxo atômico)
  tempAssets TempAsset[]

  // Lojinha: cliente logado (pedidos) e trilha no painel
  shopOrdersAsCustomer ShopOrder[]           @relation("ShopOrderCustomer")
  shopOrderStatusLogs  ShopOrderStatusLog[] @relation("ShopOrderStatusLogActor")

  boardAuditLogs BoardAuditLog[]
}

// =========================================================
// 3. NOTÍCIAS & CONTEÚDO
// =========================================================

model NewsCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts NewsPost[]
}

model NewsPost {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  excerpt     String?
  contentHtml String
  status      PostStatus @default(DRAFT)

  isFeatured Boolean @default(false)
  views      Int     @default(0)

  showFeaturedImage Boolean @default(true)
  enableGallery     Boolean @default(false)
  enableLinks       Boolean @default(false)

  // capa (asset)
  coverAssetId String?
  coverAsset   NewsAsset? @relation("NewsCoverAsset", fields: [coverAssetId], references: [id], onDelete: SetNull)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  categoryId String?
  category   NewsCategory? @relation(fields: [categoryId], references: [id])

  authorId String
  author   User   @relation("PostAuthor", fields: [authorId], references: [id])

  editorId String?
  editor   User?   @relation("PostEditor", fields: [editorId], references: [id])

  // ✅ relação nomeada (resolve ambiguidade)
  assets NewsAsset[] @relation("NewsPostAssets")
  links  NewsLink[]

  @@index([status, publishedAt])
  @@index([categoryId])
  @@index([authorId])
  @@index([isFeatured])
}

model NewsAsset {
  id String @id @default(cuid())

  postId String
  // ✅ relação nomeada (resolve ambiguidade)
  post   NewsPost @relation("NewsPostAssets", fields: [postId], references: [id], onDelete: Cascade)

  type AssetType     @default(IMAGE)
  role NewsAssetRole @default(GALLERY)

  url   String
  order Int    @default(0)

  title   String?
  caption String?

  mimeType  String?
  sizeBytes Int?
  width     Int?
  height    Int?

  thumbUrl String?

  createdAt DateTime @default(now())

  // ✅ back relation pra capa (opcional, mas evita ambiguidade e deixa explícito)
  newsPostsAsCover NewsPost[] @relation("NewsCoverAsset")

  @@index([postId, type])
  @@index([postId, role])
  @@index([postId, order])
}

model NewsLink {
  id String @id @default(cuid())

  postId String
  post   NewsPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  url         String
  title       String?
  description String?

  order Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId, order])
  @@index([postId])
}

// ✅ TMP uploads (fase A — arquivos temporários antes do commit)
model TempAsset {
  id String @id @default(cuid())

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  kind TempAssetKind

  // URLs usadas no preview do frontend (ex: /uploads/news/tmp/news/<id>/cover.webp)
  url      String
  thumbUrl String?

  // caminho relativo dentro da pasta de uploads do servidor
  // ex: "news/tmp/news/<id>/cover.webp"
  relPath String

  mimeType  String?
  sizeBytes Int?
  width     Int?
  height    Int?

  originalName String?
  sha256       String?

  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([ownerId])
  @@index([expiresAt])
  @@index([kind])
  @@map("temp_assets")
}

// =========================================================
// 4. PORTAL DA TRANSPARÊNCIA (Documentos)
// =========================================================

model DocumentCategory {
  id        String @id @default(cuid())
  name      String @unique
  slug      String @unique
  sortOrder Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents Document[]
}

model Document {
  id          String         @id @default(cuid())
  title       String
  slug        String         @unique
  description String?

  // Exposto publicamente (ex: /uploads/documents/2026-01/abc.pdf)
  fileUrl     String
  // Caminho real no servidor (pra deletar com segurança)
  filePath    String

  mimeType     String  @default("application/pdf")
  originalName String?
  sizeBytes    Int?

  status      DocumentStatus @default(PUBLISHED)
  downloads   Int            @default(0)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  categoryId String?
  category   DocumentCategory? @relation(fields: [categoryId], references: [id])

  uploadedById String?
  uploadedBy   User?   @relation("DocumentUploader", fields: [uploadedById], references: [id])

  @@index([status, publishedAt])
  @@index([categoryId])
  @@index([createdAt])
}

// =========================================================
// 5. INSTITUCIONAL (Grêmios, Gestão)
// =========================================================

model Guild {
  id     String @id @default(cuid())
  name   String
  campus String

  logoUrl  String?
  coverUrl String?
  history  String? @db.Text

  email     String?
  instagram String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets GuildAsset[]

  @@map("guilds")
}

model GuildAsset {
  id      String @id @default(cuid())
  guildId String
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)

  type  AssetType @default(IMAGE)
  url   String
  title String?

  createdAt DateTime @default(now())

  @@map("guild_assets")
}

model Position {
  id        String  @id @default(cuid())
  name      String  @unique
  group     String?
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members Member[]
}

model Member {
  id       String  @id @default(cuid())
  name     String
  photoUrl String?
  campus   String?
  bio      String?

  instagram String?
  linkedin  String?
  email     String?

  isActive Boolean @default(true)

  positionId String?
  position   Position? @relation(fields: [positionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =========================================================
// 5b. LOJINHA — catálogo + pedidos (marketplace)
// =========================================================

model ShopCategory {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String? @db.Text
  imageUrl    String?
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  parentId String?
  parent   ShopCategory?  @relation("ShopCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children ShopCategory[] @relation("ShopCategoryTree")

  products ShopProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([isActive, sortOrder])
  @@map("shop_categories")
}

model ShopProduct {
  id              String            @id @default(cuid())
  title           String
  slug            String            @unique
  excerpt     String?
  /** Texto simples (coluna legada no BD: `descriptionHtml`). */
  description String? @map("descriptionHtml") @db.Text
  status          ShopProductStatus @default(DRAFT)
  sortOrder       Int               @default(0)
  metaTitle       String?
  metaDescription String?
  publishedAt     DateTime?

  price          Decimal @db.Decimal(12, 2)
  compareAtPrice Decimal? @db.Decimal(12, 2)
  stockQuantity  Int     @default(0)

  categoryId String?
  category   ShopCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  images           ShopProductImage[]
  specifications   ShopProductSpecification[]
  orderItems       ShopOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, publishedAt])
  @@index([categoryId])
  @@index([slug])
  @@map("shop_products")
}

model ShopProductImage {
  id        String @id @default(cuid())
  productId String
  product   ShopProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  url      String
  thumbUrl String?
  alt      String?
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([productId, sortOrder])
  @@index([productId, isPrimary])
  @@map("shop_product_images")
}

model ShopProductSpecification {
  id        String      @id @default(cuid())
  productId String
  product   ShopProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  label     String
  value     String
  sortOrder Int     @default(0)

  @@index([productId, sortOrder])
  @@map("shop_product_specifications")
}

model ShopOrder {
  id           String @id @default(cuid())
  publicNumber String @unique

  customerUserId String?
  customerUser   User?   @relation("ShopOrderCustomer", fields: [customerUserId], references: [id], onDelete: SetNull)

  customerEmail   String
  customerName      String
  customerPhone     String?
  customerDocument  String?

  status         ShopOrderStatus   @default(AWAITING_PAYMENT)
  paymentStatus  ShopPaymentStatus @default(PENDING)
  paymentMethod  ShopPaymentMethod @default(UNKNOWN)

  currency String @default("BRL")

  subtotal      Decimal @db.Decimal(12, 2)
  discountTotal Decimal @default(0) @db.Decimal(12, 2)
  shippingTotal Decimal @default(0) @db.Decimal(12, 2)
  taxTotal      Decimal @default(0) @db.Decimal(12, 2)
  grandTotal    Decimal @db.Decimal(12, 2)

  shippingRecipientName String?
  shippingLine1         String?
  shippingLine2         String?
  shippingNeighborhood  String?
  shippingCity          String?
  shippingState         String?
  shippingPostalCode    String?
  shippingCountry       String  @default("BR")

  billingSameAsShipping Boolean @default(true)
  billingRecipientName  String?
  billingLine1          String?
  billingLine2          String?
  billingCity           String?
  billingState          String?
  billingPostalCode     String?
  billingCountry        String?

  customerNote String? @db.Text
  internalNote String? @db.Text

  paidAt       DateTime?
  shippedAt    DateTime?
  deliveredAt  DateTime?
  cancelledAt  DateTime?
  cancelReason String?

  paymentExternalId String?
  paymentMetadata   String? @db.Text

  items      ShopOrderItem[]
  statusLogs ShopOrderStatusLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([paymentStatus])
  @@index([customerUserId])
  @@index([customerEmail])
  @@map("shop_orders")
}

/// Linha do pedido: preços e textos congelados no momento da compra.
model ShopOrderItem {
  id      String    @id @default(cuid())
  orderId String
  order   ShopOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   ShopProduct @relation(fields: [productId], references: [id], onDelete: Restrict)

  quantity Int

  unitPriceSnapshot    Decimal @db.Decimal(12, 2)
  compareAtSnapshot    Decimal? @db.Decimal(12, 2)
  lineSubtotalSnapshot Decimal @db.Decimal(12, 2)

  productTitleSnapshot String
  /// Legado (pedidos antigos com variação); novos pedidos podem deixar nulo.
  variantNameSnapshot String?
  skuSnapshot         String?
  imageUrlSnapshot    String?

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([productId])
  @@map("shop_order_items")
}

model ShopOrderStatusLog {
  id      String    @id @default(cuid())
  orderId String
  order   ShopOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  fromOrderStatus   ShopOrderStatus?
  toOrderStatus     ShopOrderStatus
  fromPaymentStatus ShopPaymentStatus?
  toPaymentStatus   ShopPaymentStatus?

  note String? @db.Text

  createdByUserId String?
  createdBy       User?   @relation("ShopOrderStatusLogActor", fields: [createdByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
  @@map("shop_order_status_logs")
}

/// Código de acesso de uso único (e-mail → “Meus pedidos” na vitrine).
model ShopGuestOrderOtp {
  id        String    @id @default(cuid())
  emailNorm String    @map("email_norm")
  codeHash  String    @map("code_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([emailNorm, usedAt, expiresAt])
  @@map("shop_guest_order_otps")
}

model FaqItem {
  id        String  @id @default(cuid())
  question  String
  answer    String  @db.Text
  sortOrder Int     @default(0)
  isPublic  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =========================================================
// 6. GESTÃO DE PESSOAL & TRANSPARÊNCIA (Diretorias REGIF)
// =========================================================

enum IfrnCampus {
  AVANCADO_LAJES
  PAU_DOS_FERROS
  MACAU
  NATAL_CENTRO_HISTORICO
  NATAL_CENTRAL
  JOAO_CAMARA
  CANGUARETAMA
  APODI
  PARELHAS
  CEARA_MIRIM
  IPANGUACU
  SAO_PAULO_DO_POTENGI
  PARNAMIRIM
  NOVA_CRUZ
  NATAL_ZONA_NORTE
  CURRAIS_NOVOS
  SANTA_CRUZ
  CAICO
  SAO_GONCALO_DO_AMARANTE
  MOSSORO
}

enum BoardRoleType {
  EXECUTIVE
  PLENA
}

enum BoardMandateStatus {
  ACTIVE
  ARCHIVED
}

// Status do vínculo do membro com o cargo no mandato (Art. 42 + transparência)
enum BoardAssignmentStatus {
  ACTIVE
  EGRESSO
  RENUNCIA
  VACANTE
}

enum BoardVacancyReason {
  MORTE
  ABANDONO
  RENUNCIA
  TRANCAMENTO_OU_JUBILAMENTO
  CONCLUSAO_DE_CURSO
  OUTRO
}

enum BoardAuditAction {
  CREATE
  UPDATE
  DELETE
  ASSIGN
  UNASSIGN
  DECLARE_VACANCY
  SUBSTITUTE
  STATUS_CHANGE
  GENERATE_PORTARIA
}

model BoardMember {
  id String @id @default(cuid())

  // Identificação e contato
  name      String
  cpf       String @unique @db.VarChar(14) // interno (não expor em endpoints públicos)
  email     String?
  phone     String?

  campus IfrnCampus
  course String?
  suapRegistration String? @map("suap_registration")

  academicAttendancePct Int @default(0) @map("academic_attendance_pct") // >= 75% (Art. 41, II)

  birthDate DateTime @map("birth_date")
  isEmancipated Boolean @default(false) @map("is_emancipated")

  // Perfil público
  photoUrl String?
  publicBio String? @db.Text @map("public_bio")

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments BoardAssignment[]
  vacancyEvents BoardVacancyEvent[]

  @@index([campus])
  @@index([isActive])
  @@map("board_members")
}

model BoardRole {
  id String @id @default(cuid())

  title String @unique
  description String? @db.Text
  type BoardRoleType
  hierarchyLevel Int @default(0) @map("hierarchy_level")

  // Texto público com “o que faz” baseado no Estatuto (Art. 62–80)
  competenciesText String? @db.Text @map("competencies_text")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments BoardAssignment[]
  vacancyEvents BoardVacancyEvent[]

  @@index([type, hierarchyLevel])
  @@map("board_roles")
}

model BoardMandate {
  id String @id @default(cuid())

  // Gestão (período flexível — pode não ter fim definido)
  label String @default("Gestão") // ex.: "Gestão 2026" (ajustável no admin)

  startsAt DateTime @map("starts_at")
  endsAt   DateTime? @map("ends_at")

  inaugurationAt DateTime? @map("inauguration_at")
  status BoardMandateStatus @default(ACTIVE)

  // Textos exibidos em “Quem somos” / transparência (opcionais; sobrescreva quando mudar a gestão)
  publicTagline      String? @db.Text @map("public_tagline")
  publicIntro        String? @db.Text @map("public_intro")
  publicMission      String? @db.Text @map("public_mission")
  publicActivities   String? @db.Text @map("public_activities")
  publicContact      String? @db.Text @map("public_contact")
  publicClosingNote  String? @db.Text @map("public_closing_note")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments BoardAssignment[]
  vacancyEvents BoardVacancyEvent[]

  @@index([status, startsAt])
  @@map("board_mandates")
}

model BoardAssignment {
  id String @id @default(cuid())

  mandateId String
  mandate   BoardMandate @relation(fields: [mandateId], references: [id], onDelete: Cascade)

  roleId String
  role   BoardRole @relation(fields: [roleId], references: [id], onDelete: Restrict)

  memberId String?
  member   BoardMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  // Para Diretoria Plena (Art. 43, §1º): 1 representante por campus no mandato
  campus IfrnCampus?

  status BoardAssignmentStatus @default(ACTIVE)

  isCurrent Boolean @default(true) @map("is_current")
  assignedAt DateTime @default(now()) @map("assigned_at")
  endedAt DateTime? @map("ended_at")

  vacancyReason BoardVacancyReason?
  vacancyNote String? @db.Text @map("vacancy_note")
  portariaNumber String? @map("portaria_number")
  portariaPdfUrl String? @map("portaria_pdf_url")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vacancyEvents BoardVacancyEvent[]

  @@index([mandateId, isCurrent])
  @@index([roleId, isCurrent])
  @@index([memberId, isCurrent])
  @@index([campus, isCurrent])

  // Um cargo só pode ter 1 ocupação “corrente” por mandato (evita duplicidade no organograma)
  @@unique([mandateId, roleId, isCurrent])

  // Evita acúmulo de cargos por membro no mandato (Art. 58, parágrafo único)
  @@unique([mandateId, memberId, isCurrent])
  // campus pode repetir no mesmo mandato (composição extraordinária: mais de um membro por campus);
  // o primeiro nomeado por campus é a indicação “oficial”; demais entram como multi-representação (ver alertas admin).

  @@map("board_assignments")
}

model BoardVacancyEvent {
  id String @id @default(cuid())

  mandateId String
  mandate   BoardMandate @relation(fields: [mandateId], references: [id], onDelete: Cascade)

  assignmentId String?
  assignment   BoardAssignment? @relation(fields: [assignmentId], references: [id], onDelete: SetNull)

  roleId String
  role   BoardRole @relation(fields: [roleId], references: [id], onDelete: Restrict)

  memberId String?
  member   BoardMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  reason BoardVacancyReason
  note   String? @db.Text

  portariaNumber String?
  portariaPdfUrl String?

  occurredAt DateTime @default(now()) @map("occurred_at")
  createdAt  DateTime @default(now())

  @@index([mandateId, occurredAt])
  @@index([roleId, occurredAt])
  @@map("board_vacancy_events")
}

model BoardAuditLog {
  id String @id @default(cuid())

  actorUserId String?
  actorUser   User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  action BoardAuditAction

  entityType String @map("entity_type")
  entityId   String @map("entity_id")

  before Json?
  after  Json?
  meta   Json?

  createdAt DateTime @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("board_audit_logs")
}
